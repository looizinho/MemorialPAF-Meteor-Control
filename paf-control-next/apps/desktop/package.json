{
  "name": "@paf/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx src/backend/server.ts",
    "build": "npm run build:frontend",
    "build:frontend": "vite build",
    "test": "vitest run",
    "lint": "echo 'lint placeholder'",
